  "inputSchema": {
    "type": "object",
    "properties": {
      "system": {
        "type": "object",
        "title": "/Script/Niagara.NiagaraSystem",
        "description": "要添加发射器的Niagara系统",
        "properties": {
          "refPath": {
            "type": "string",
            "description": "存储为软路径字符串的引用。"
          }
        },
        "required": [
          "refPath"
        ]
      },
      "templateEmitter": {
        "type": "object",
        "title": "/Script/Niagara.NiagaraEmitter",
        "description": "用作新发射器模板的发射器资产",
        "properties": {
          "refPath": {
            "type": "string",
            "description": "存储为软路径字符串的引用。"
          }
        },
        "required": [
          "refPath"
        ]
      },
      "emitterName": {
        "type": "string",
        "description": "新发射器实例的名称"
      }
    },
    "required": [
      "system",
      "templateEmitter",
      "emitterName"
    ]
  },
